{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start"
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "spec:plan",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/spec-plan-guard"
          }
        ]
      }
    ]
  }
}
